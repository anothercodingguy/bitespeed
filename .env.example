# ──────────────────────────────────────────────
# Bitespeed Identity Reconciliation — Environment
# ──────────────────────────────────────────────

# PostgreSQL connection string (required)
# For local dev:   postgresql://user:password@localhost:5432/bitespeed?schema=public
# For Render:      Use the Internal Database URL from your Render Postgres instance
DATABASE_URL="postgresql://user:password@localhost:5432/bitespeed?schema=public"

# Server port (optional, defaults to 3000 locally, Render uses 10000)
PORT=3000

# Node environment
NODE_ENV=development
